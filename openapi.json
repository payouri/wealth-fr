              "WID",
              "INSEE",
              "DGFiP"
            ],
            "title": "Source",
            "type": "string"
          },
          "unite": {
            "enum": [
              "adulte",
              "menage",
              "foyer_fiscal"
            ],
            "title": "Unite",
            "type": "string"
