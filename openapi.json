      "ObservationsResponse": {
        "description": "Response for GET /api/observations \u2014 matching rows co-located, never merged.\n\n`query` echoes the resolved filters; `total` is the full matched count (so a\nconsumer can detect truncation against `limit`); `observations` is the\n`limit`/`offset` page. Never resolves to one Convention and never 422s on\nambiguity (ADR 0004).",
        "properties": {
          "limit": {
            "title": "Limit",
            "type": "integer"
          },
          "observations": {
            "items": {
              "$ref": "#/components/schemas/Observation"
            },
            "title": "Observations",
            "type": "array"
          },
          "offset": {
            "title": "Offset",
            "type": "integer"
          },
          "query": {
            "additionalProperties": true,
            "title": "Query",
            "type": "object"
          },
          "total": {
            "title": "Total",
            "type": "integer"
          }
        },
        "required": [
          "query",
          "total",
          "limit",
          "offset",
          "observations"
        ],
        "title": "ObservationsResponse",
        "type": "object"
