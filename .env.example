# WID.world API key — base64 string sent VERBATIM as x-api-key (do NOT re-encode).
# Default below is the public key embedded in the official R package; it may rotate
# or be rate-limited. The pipeline falls back to a local file if auth fails.
WID_API_KEY_B64=rYFByOB0ioaPATwHtllMI71zLOZSK0Ic5veQonJP

# DGFiP source URLs (jalon 6.5). There is NO single URL: the IFI national stats
# are 3 files under stable /node/ links. Leave empty to use the built-in default
# registry (the 3 links below); override with a comma/space-separated list.
#   DGFIP_SOURCE_URLS=https://www.impots.gouv.fr/node/25582 https://www.impots.gouv.fr/node/25583 https://www.impots.gouv.fr/node/25584
DGFIP_SOURCE_URLS=
# Legacy single URL — still honoured (appended to the registry) for back-compat.
DGFIP_IFI_XLS_URL=

# Backend: path to the harmonized dataset the API reads (Parquet preferred).
DATASET_PARQUET=pipeline/out/dataset_concentration_patrimoine_fr.parquet
DATASET_CSV=pipeline/out/dataset_concentration_patrimoine_fr.csv
