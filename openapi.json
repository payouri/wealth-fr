  "info": {
    "description": "Explore harmonized wealth-concentration series for France since 2000.",
    "title": "Concentration du patrimoine en France",
    "version": "0.0.1"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/compare": {
      "get": {
        "description": "Same indicateur/groupe across several sources. `sources` = CSV list.\n\nEach returned series keeps its own Convention; never merged (jalon 5, ADR\n0003). A source still spanning more than one Convention surfaces the same\n422 \"pick a Convention\" contract as /api/series.",
        "operationId": "compare_api_compare_get",
        "parameters": [
          {
            "in": "query",
            "name": "indicateur",
            "required": true,
            "schema": {
              "enum": [
                "part_patrimoine",
                "gini",
                "patrimoine_moyen",
                "seuil",
                "nb_foyers",
                "impot_moyen"
              ],
              "title": "Indicateur",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "groupe",
            "required": true,
            "schema": {
              "title": "Groupe",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "sources",
            "required": true,
            "schema": {
              "title": "Sources",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/Series"
                  },
                  "title": "Response Compare Api Compare Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AmbiguousConventionDetail"
                }
              }
            },
            "description": "Unprocessable Content"
          }
        },
        "summary": "Compare"
      }
    },
    "/api/export.csv": {
      "get": {
        "description": "Stream the resolved tidy rows as CSV (jalon 9).\n\nReuses the jalon-3 resolver (`resolve_rows`), so the export is exactly the\nrows the chart was drawn from \u2014 same Convention guard, same single-Mill\u00e9sime\npick, same 422 \"pick a Convention\" contract (handled centrally).",
        "operationId": "export_csv_api_export_csv_get",
        "parameters": [
          {
            "in": "query",
            "name": "source",
            "required": true,
            "schema": {
              "enum": [
                "WID",
                "INSEE",
                "DGFiP"
              ],
              "title": "Source",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "indicateur",
            "required": true,
            "schema": {
              "enum": [
                "part_patrimoine",
                "gini",
                "patrimoine_moyen",
                "seuil",
                "nb_foyers",
                "impot_moyen"
              ],
              "title": "Indicateur",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "groupe",
            "required": true,
            "schema": {
              "title": "Groupe",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "concept",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Concept"
            }
          },
          {
            "in": "query",
            "name": "unite",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "enum": [
                    "adulte",
                    "menage",
                    "foyer_fiscal"
                  ],
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Unite"
            }
          },
          {
            "in": "query",
            "name": "annee_min",
            "required": false,
            "schema": {
              "default": 2000,
              "title": "Annee Min",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "annee_max",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Annee Max"
            }
          },
          {
            "in": "query",
            "name": "euros_constants",
            "required": false,
            "schema": {
              "default": false,
              "title": "Euros Constants",
              "type": "boolean"
            }
          },
          {
            "in": "query",
            "name": "millesime",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Millesime"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AmbiguousConventionDetail"
                }
              }
            },
            "description": "Unprocessable Content"
          }
        },
        "summary": "Export Csv"
