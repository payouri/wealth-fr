# WID.world API key — base64 string sent VERBATIM as x-api-key (do NOT re-encode).
# Default below is the public key embedded in the official R package; it may rotate
# or be rate-limited. The pipeline falls back to a local file if auth fails.
WID_API_KEY_B64=rYFByOB0ioaPATwHtllMI71zLOZSK0Ic5veQonJP

# DGFiP source URLs (jalon 6.5). There is NO single URL: the IFI national stats
# are 3 files under stable /node/ links, plus the frozen ISF 1999-2017 series on
# data.gouv.fr. Leave empty to use the built-in default registry; override with a
# comma/space-separated list. Default registry:
#   https://www.impots.gouv.fr/node/25582  (IFI déciles de patrimoine)
#   https://www.impots.gouv.fr/node/25583  (IFI déciles de RFR)
#   https://www.impots.gouv.fr/node/25584  (IFI tranches de taux marginal)
#   https://www.data.gouv.fr/api/1/datasets/r/1ca0d574-22b1-47e0-9711-3538302c50d5  (ISF 1999-2017)
DGFIP_SOURCE_URLS=
# Legacy single URL — still honoured (appended to the registry) for back-compat.
DGFIP_IFI_XLS_URL=

# INSEE Melodi dataset id (issue #14). The HVP wealth aggregates are fetched live
# from the public Melodi API (no auth). Leave empty for the built-in default
# (DS_ENQPAT_DET); override only if INSEE renames the dataset.
INSEE_MELODI_DATASET=

# Backend: path to the harmonized dataset the API reads (Parquet preferred).
DATASET_PARQUET=pipeline/out/dataset_concentration_patrimoine_fr.parquet
DATASET_CSV=pipeline/out/dataset_concentration_patrimoine_fr.csv
