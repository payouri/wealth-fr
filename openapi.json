{
  "components": {
    "schemas": {
      "AmbiguousConventionDetail": {
        "description": "The `422` body when filters still span more than one Convention (ADR 0002).\n\nWraps the choices the caller can pin. `error` is a closed literal so the\nfrontend can branch on it. The `@app.exception_handler` in `main.py` produces\nthis body at runtime under a `{\"detail\": \u2026}` envelope; declaring the model via\n`responses={422: {\"model\": AmbiguousConventionDetail}}` only makes it visible\nto OpenAPI (and thus generated for the frontend).",
        "properties": {
          "choices": {
            "items": {
              "$ref": "#/components/schemas/ConventionChoice"
            },
            "title": "Choices",
            "type": "array"
          },
          "error": {
            "const": "ambiguous_convention",
            "default": "ambiguous_convention",
            "title": "Error",
            "type": "string"
          }
        },
        "required": [
          "choices"
        ],
        "title": "AmbiguousConventionDetail",
        "type": "object"
      },
      "ConventionChoice": {
        "description": "One Convention the caller may pin to resolve a 422 (ADR 0002). `unite` is\nclosed; `concept_patrimoine` stays an OPEN string (ADR 0005).",
        "properties": {
          "concept_patrimoine": {
            "title": "Concept Patrimoine",
            "type": "string"
          },
          "unite": {
            "title": "Unite",
            "type": "string"
          }
        },
        "required": [
          "unite",
          "concept_patrimoine"
        ],
        "title": "ConventionChoice",
        "type": "object"
      },
      "ConventionGroup": {
        "description": "The Conventions one Source carries: its single `unite` and the Concepts it\nspans (one per Concept \u2014 e.g. DGFiP `total`/`immobilier` across the 2018\nRupture). The Convention guard rail forbids comparing across these (CONTEXT.md).",
        "properties": {
          "concepts": {
            "items": {
              "type": "string"
            },
            "title": "Concepts",
            "type": "array"
          },
          "source": {
            "enum": [
              "WID",
              "INSEE",
              "DGFiP"
            ],
            "title": "Source",
            "type": "string"
          },
          "unite": {
            "enum": [
              "adulte",
              "menage",
              "foyer_fiscal"
            ],
            "title": "Unite",
            "type": "string"
          }
        },
        "required": [
          "source",
          "unite",
          "concepts"
        ],
        "title": "ConventionGroup",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "IndicateurSemantics": {
        "description": "Per-`indicateur` value semantics: its `unite_valeur` and whether it is\n`dimensionless`. The in-band encoding of ADR 0003 \u2014 `%`/`indice` are\ndimensionless (cross-source-comparable in *shape*); `euros*` are levels and\n`effectif` is a count (both NOT dimensionless, never overlaid across Sources).",
        "properties": {
          "dimensionless": {
            "title": "Dimensionless",
            "type": "boolean"
          },
          "indicateur": {
            "enum": [
              "part_patrimoine",
              "gini",
              "patrimoine_moyen",
              "seuil",
              "nb_foyers",
              "impot_moyen"
            ],
            "title": "Indicateur",
            "type": "string"
          },
          "unites_valeur": {
            "items": {
              "type": "string"
            },
            "title": "Unites Valeur",
            "type": "array"
          }
        },
        "required": [
          "indicateur",
          "unites_valeur",
          "dimensionless"
        ],
        "title": "IndicateurSemantics",
        "type": "object"
      },
